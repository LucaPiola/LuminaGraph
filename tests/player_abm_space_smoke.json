{
  "version": 1,
  "modelTitle": "Player smoke: agenti e spazio",
  "view": {
    "zoom": 0.95,
    "showGrid": true,
    "gridSize": 20,
    "scrollLeft": 20,
    "scrollTop": 0
  },
  "execution": {
    "t0": 0,
    "dt": 1,
    "t1": 12,
    "delayMs": 100,
    "decimals": 3,
    "integrator": "euler",
    "strictDefinitions": false
  },
  "nodes": [
    {
      "id": 1,
      "name": "seed",
      "output": false,
      "type": "parameter",
      "x": 140,
      "y": 180,
      "width": 140,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        { "key": "note formula", "value": "" },
        { "key": "descrizione", "value": "Popolazione base di agenti con coordinate X,Y" }
      ],
      "valueExpression": "agents([\"ID\",\"X\",\"Y\",\"STATE\"],[[1,0,0,1],[2,1,1,1],[3,2,2,0],[4,3,3,1],[5,4,1,0]])"
    },
    {
      "id": 2,
      "name": "agenti",
      "output": true,
      "type": "algebraic",
      "x": 360,
      "y": 180,
      "width": 140,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        { "key": "note formula", "value": "" },
        { "key": "descrizione", "value": "Popolazione traslata lungo X in funzione del tempo" }
      ],
      "input": false,
      "valueExpression": "setCol(seed, \"X\", (col(seed, \"X\") + time) % 6)"
    },
    {
      "id": 3,
      "name": "space",
      "output": true,
      "type": "algebraic",
      "x": 600,
      "y": 180,
      "width": 140,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        { "key": "note formula", "value": "" },
        { "key": "descrizione", "value": "Indice spaziale 6x6 costruito sugli agenti" }
      ],
      "input": false,
      "valueExpression": "agentSpace(agenti, \"X\", \"Y\", \"ID\", [6,6])"
    },
    {
      "id": 4,
      "name": "occ",
      "output": true,
      "type": "algebraic",
      "x": 840,
      "y": 180,
      "width": 140,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        { "key": "note formula", "value": "" },
        { "key": "descrizione", "value": "Matrice di occupazione dello spazio" }
      ],
      "input": false,
      "valueExpression": "spaceMatrix(space)"
    },
    {
      "id": 5,
      "name": "alive",
      "output": true,
      "type": "algebraic",
      "x": 600,
      "y": 320,
      "width": 140,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        { "key": "note formula", "value": "" },
        { "key": "descrizione", "value": "Numero di agenti con STATE=1" }
      ],
      "input": false,
      "valueExpression": "sum(col(agenti, \"STATE\"))"
    }
  ],
  "edges": [
    { "id": 1, "from": 1, "to": 2, "sourcePort": "", "targetPort": "", "controlPoints": [] },
    { "id": 2, "from": 2, "to": 3, "sourcePort": "", "targetPort": "", "controlPoints": [] },
