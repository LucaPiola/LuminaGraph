        }
      ],
      "valueExpression": "0.5"
    },
    {
      "id": 4,
      "name": "space",
      "output": true,
      "global": false,
      "type": "state",
      "x": 1060,
      "y": 660,
      "width": 170,
      "height": 90,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "note formula",
          "value": ""
        },
        {
          "key": "descrizione",
          "value": "0 = vuoto, 1 = tipo A, 2 = tipo B"
        }
      ],
      "stateTransition": "if(size(unhappyCoords,0)==0 or size(emptyCoords,0)==0, this, setAt(setAt(this, moveTo, this[moveFrom]), moveFrom, 0))",
      "initialState": "array([n,n], if(rand() < vacancy, 0, if(rand() < 0.5, 1, 2)))"
    },
    {
      "id": 5,
      "name": "occupiedN",
      "output": false,
      "global": false,
      "type": "algebraic",
      "x": 1220,
      "y": 820,
      "width": 170,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "note formula",
          "value": ""
        },
        {
          "key": "descrizione",
          "value": "Numero di vicini occupati"
        }
      ],
      "input": false,
      "valueExpression": "array(size(space), count($value != 0, neighbors(space, $0, $1, true, true)))"
    },
    {
      "id": 6,
      "name": "sameN",
      "output": false,
      "global": false,
      "type": "algebraic",
      "x": 640,
      "y": 740,
      "width": 170,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "note formula",
          "value": ""
        },
        {
          "key": "descrizione",
          "value": "Numero di vicini dello stesso tipo"
        }
      ],
      "input": false,
      "valueExpression": "array(size(space), if(space[$0,$1] == 0, 0, count($value == space[$0,$1], neighbors(space, $0, $1, true, true))))"
    },
    {
      "id": 7,
      "name": "similarity",
      "output": false,
      "global": false,
      "type": "algebraic",
      "x": 880,
      "y": 820,
      "width": 180,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "note formula",
          "value": ""
        },
        {
          "key": "descrizione",
          "value": "Quota di vicini simili"
        }
      ],
      "input": false,
      "valueExpression": "array(size(space), if(space[$0,$1] == 0 or occupiedN[$0,$1] == 0, 1, sameN[$0,$1] / occupiedN[$0,$1]))"
    },
    {
      "id": 8,
      "name": "unhappyCoords",
      "output": false,
      "global": false,
      "type": "algebraic",
      "x": 880,
      "y": 520,
      "width": 190,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "note formula",
          "value": ""
        },
        {
          "key": "descrizione",
          "value": "Coordinate degli agenti insoddisfatti"
        }
      ],
      "input": false,
      "valueExpression": "filter(similarity[$value] < tau, coords(space), \"rows\")"
    },
    {
      "id": 9,
      "name": "emptyCoords",
      "output": false,
      "global": false,
      "type": "algebraic",
      "x": 900,
