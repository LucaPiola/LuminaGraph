        },
        {
          "key": "descrizione",
          "value": "Coordinate delle celle vuote"
        }
      ],
      "input": false,
      "valueExpression": "coords(space, 0)"
    },
    {
      "id": 10,
      "name": "moveFrom",
      "output": false,
      "global": false,
      "type": "algebraic",
      "x": 1260,
      "y": 400,
      "width": 160,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "note formula",
          "value": ""
        },
        {
          "key": "descrizione",
          "value": "Cella di partenza scelta a caso"
        }
      ],
      "input": false,
      "valueExpression": "if(size(unhappyCoords,0) == 0, [-1,-1], choice(unhappyCoords))"
    },
    {
      "id": 11,
