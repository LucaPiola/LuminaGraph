{
  "modelTitle": "Modello epidemiologico SIR agent-based con mobilita",
  "modelProperties": [],
  "execution": {
    "t0": 0,
    "dt": 1,
    "t1": 200,
    "delayMs": 1,
    "decimals": 3,
    "integrator": "euler",
    "strictDefinitions": false
  },
  "nodes": [
    {
      "id": 1,
      "name": "n",
      "output": false,
      "type": "parameter",
      "x": 120,
      "y": 420,
      "width": 120,
      "height": 70,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Lato della griglia quadrata"
        }
      ],
      "valueExpression": "30"
    },
    {
      "id": 2,
      "name": "agentCount",
      "output": false,
      "type": "parameter",
      "x": 120,
      "y": 520,
      "width": 140,
      "height": 70,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero totale di agenti"
        }
      ],
      "valueExpression": "300"
    },
    {
      "id": 3,
      "name": "beta",
      "output": false,
      "type": "parameter",
      "x": 120,
      "y": 140,
      "width": 120,
      "height": 70,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Probabilita di contagio per vicino infetto"
        }
      ],
      "valueExpression": "0.27"
    },
    {
      "id": 4,
      "name": "gamma",
      "output": false,
      "type": "parameter",
      "x": 120,
      "y": 240,
      "width": 120,
      "height": 70,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Probabilita di guarigione per passo"
        }
      ],
      "valueExpression": "0.02"
    },
    {
      "id": 5,
      "name": "moversPerStep",
      "output": false,
      "type": "parameter",
      "x": 120,
      "y": 340,
      "width": 150,
      "height": 70,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero atteso di agenti che si spostano per passo"
        }
      ],
      "valueExpression": "15"
    },
    {
      "id": 6,
      "name": "moveProb",
      "output": false,
      "type": "algebraic",
      "x": 360,
      "y": 340,
      "width": 150,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Probabilita individuale di spostamento per passo"
        }
      ],
      "valueExpression": "min(1, moversPerStep / agentCount)"
    },
    {
      "id": 7,
      "name": "rows",
      "output": false,
      "type": "state",
      "x": 360,
      "y": 460,
      "width": 150,
      "height": 86,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Righe correnti degli agenti"
        }
      ],
      "stateTransition": "if(rand() < moveProb, randInt(n - 1), self)",
      "initialState": "array(agentCount, randInt(n - 1))"
    },
    {
      "id": 8,
      "name": "cols",
      "output": false,
      "type": "state",
      "x": 360,
      "y": 580,
      "width": 150,
      "height": 86,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Colonne correnti degli agenti"
        }
      ],
      "stateTransition": "if(rand() < moveProb, randInt(n - 1), self)",
      "initialState": "array(agentCount, randInt(n - 1))"
    },
    {
      "id": 9,
      "name": "sir",
      "output": true,
      "type": "state",
      "x": 380,
      "y": 180,
      "width": 170,
      "height": 86,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "0=suscettibile, 1=infetto, 2=rimosso"
        }
      ],
      "stateTransition": "if(self == 0 and rand() < beta * infNeighbors[$i] / 8, 1, if(self == 1 and rand() < gamma, 2, self))",
      "initialState": "setAt(array(agentCount, 0), randInt(agentCount - 1), 1)"
    },
    {
      "id": 10,
      "name": "infectedGrid",
      "output": true,
      "type": "algebraic",
      "x": 720,
      "y": 280,
      "width": 190,
      "height": 86,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero di agenti infetti per cella"
        }
      ],
      "valueExpression": "grid(rows, cols, \"sum\", if(sir == 1, 1, 0))"
    },
    {
      "id": 11,
      "name": "occupancy",
      "output": false,
      "type": "algebraic",
      "x": 720,
      "y": 400,
      "width": 190,
      "height": 86,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero totale di agenti per cella"
        }
      ],
      "valueExpression": "grid(rows, cols, \"sum\", 1)"
    },
    {
      "id": 12,
      "name": "infNeighbors",
      "output": false,
      "type": "algebraic",
      "x": 720,
      "y": 540,
      "width": 210,
      "height": 86,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero di celle vicine con almeno un infetto"
        }
      ],
      "valueExpression": "array(size(sir), count($value > 0, neighbors(infectedGrid, rows[$0], cols[$0], true, true)))"
    },
    {
      "id": 13,
      "name": "S",
      "output": true,
      "type": "algebraic",
      "x": 980,
      "y": 120,
      "width": 130,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero di suscettibili"
        }
      ],
      "valueExpression": "count($value == 0, sir)"
    },
    {
      "id": 14,
      "name": "I",
      "output": true,
      "type": "algebraic",
      "x": 980,
      "y": 220,
      "width": 130,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero di infetti"
        }
      ],
      "valueExpression": "count($value == 1, sir)"
    },
    {
      "id": 15,
      "name": "R",
      "output": true,
      "type": "algebraic",
      "x": 980,
      "y": 320,
      "width": 130,
      "height": 76,
      "fillColor": "",
      "strokeColor": "",
      "properties": [
        {
          "key": "descrizione",
          "value": "Numero di rimossi"
        }
      ],
      "valueExpression": "count($value == 2, sir)"
    }
  ],
